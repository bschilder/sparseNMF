# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Tests / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# Docs
docs/_build/
docs/_autosummary/

# Benchmark run logs (the orchestrator emits these into the run dir;
# results.csv/json/md + figures are the artifacts we keep).
benchmarks/*.log
benchmarks/runs/*/orchestrator.log
benchmarks/runs/*/*.log

# IDE / OS
.vscode/
.idea/
.DS_Store

# Jupyter checkpoints
.ipynb_checkpoints/

# Local scratch
*.npz
!data/*.npz
*.pkl
*.pt
*.ckpt
*.h5ad
scratch/
artifacts/

# coverage.py annotate output (stray artifacts when devs use --cov-report=annotate)
*,cover
.claude/
